{
  "name": "prisma-effect-kysely",
  "version": "5.4.0",
  "description": "Prisma generator that creates Effect Schema types from Prisma schema compatible with Kysely",
  "license": "MIT",
  "author": "Samuel Ho",
  "main": "dist/kysely/helpers.js",
  "bin": {
    "prisma-effect-kysely": "dist/generator/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/kysely/helpers.d.ts",
      "import": "./dist/kysely/helpers.js"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "import": "./dist/generator/index.js"
    },
    "./kysely": {
      "types": "./dist/kysely/helpers.d.ts",
      "import": "./dist/kysely/helpers.js"
    },
    "./error": {
      "types": "./dist/kysely/helpers.d.ts",
      "import": "./dist/kysely/helpers.js"
    },
    "./runtime": {
      "types": "./dist/kysely/helpers.d.ts",
      "import": "./dist/kysely/helpers.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "keywords": [
    "prisma",
    "generator",
    "effect",
    "schema",
    "typescript",
    "type-safety",
    "prisma-generator",
    "effect-ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samuelho-dev/prisma-effect-kysely.git"
  },
  "bugs": {
    "url": "https://github.com/samuelho-dev/prisma-effect-kysely/issues"
  },
  "homepage": "https://github.com/samuelho-dev/prisma-effect-kysely#readme",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.3.5",
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepublishOnly": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "effect": "^3.19.14",
    "kysely": "^0.28.9"
  },
  "peerDependenciesMeta": {
    "kysely": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@effect/vitest": "^0.29.0",
    "@eslint/js": "^10.0.0",
    "@prisma/generator-helper": "^7.8.0",
    "@prisma/internals": "^7.8.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "effect": "~3.21.2",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "kysely": "^0.28.16",
    "lint-staged": "^16.4.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
